{
  "manifest_version": 3,
  "name": "動畫瘋截圖小工具",
  "version": "3.0.1",
  "description": "在巴哈姆特動畫瘋頁面手動截取目前可見的播放器畫面。",
  "icons": {
    "16": "icons/icon16.png",
    "32": "icons/icon32.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "permissions": [
    "activeTab",
    "clipboardWrite",
    "downloads",
    "offscreen",
    "storage",
    "tabs"
  ],
  "host_permissions": [
    "https://ani.gamer.com.tw/*"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "action": {
    "default_popup": "popup.html",
    "default_title": "動畫瘋截圖小工具",
    "default_icon": {
      "16": "icons/icon16.png",
      "32": "icons/icon32.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "content_scripts": [
  {
    "matches": ["https://ani.gamer.com.tw/*"],
    "js": ["content.js"],
    "run_at": "document_idle"
  }
],
"web_accessible_resources": [
  {
    "resources": ["gif.worker.js"],
    "matches": ["https://ani.gamer.com.tw/*", "https://*.gamer.com.tw/*"]
  }
],
  "commands": {
    "capture-screenshot": {
      "description": "截取動畫瘋播放器畫面"
    }
  }
}
